{
  "manifest_version": 3,
  "name": "IPA to English (Wikipedia)",
  "version": "1.0.0",
  "description": "Decode highlighted IPA using Help:IPA/English-style approximations.",
  "permissions": ["contextMenus", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
